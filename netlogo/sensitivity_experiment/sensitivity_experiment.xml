    <enumeratedValueSet variable="el-farol-threshold"><value value="0.5"/><value value="0.6"/><value value="0.7"/></enumeratedValueSet>
    <enumeratedValueSet variable="n-sim-days"><value value="20"/></enumeratedValueSet>
