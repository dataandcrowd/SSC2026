<?xml version="1.0" encoding="us-ascii"?>
<!DOCTYPE experiments SYSTEM "behaviorspace.dtd">
<experiments>

  <!-- Pay (exponential decay): vary price sensitivity base-beta -->
  <experiment name="sensitivity-pay" repetitions="1" runMetricsEveryStep="true">
    <setup>setup</setup>
    <go>go-days</go>
    <exitCondition>current-sim-day &gt;= n-sim-days</exitCondition>
    <metric>peak-vc-inner</metric>
    <metric>current-sim-day</metric>
    <enumeratedValueSet variable="decision-rule"><value value="&quot;Exp-Decay&quot;"/></enumeratedValueSet>
    <enumeratedValueSet variable="fee-regime"><value value="&quot;No-Charge&quot;"/><value value="&quot;tou&quot;"/></enumeratedValueSet>
    <enumeratedValueSet variable="base-beta"><value value="0.25"/><value value="0.5"/><value value="1.0"/></enumeratedValueSet>
    <enumeratedValueSet variable="n-sim-days"><value value="20"/></enumeratedValueSet>
  </experiment>

