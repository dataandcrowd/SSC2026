<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[extensions [table csv]

globals
[
  grid-x-inc               ;; the amount of patches in between two roads in the x direction
  grid-y-inc               ;; the amount of patches in between two roads in the y direction
  acceleration             ;; the constant that controls how much a car speeds up or slows down by if
                           ;; it is to accelerate or decelerate
  phase                    ;; keeps track of the phase
  num-cars-stopped         ;; the number of cars that are stopped during a single pass thru the go procedure
  current-light            ;; the currently selected light

  ;; patch agentsets
  intersections ;; agentset containing the patches that are intersections
  roads         ;; agentset containing the patches that are roads
  
  road-flow-run  ;; table: road-id -> number of camera hits in THIS run
  
  cap-max-flow  ;; table: "(x,y)" -> max_flow
  cap-flow-per-tick ;; table: "(x,y)" -> flow_per_tick
  
  vc-window  ;; length of VC measurement window (ticks)
  vc-tick-counter ;; counts ticks within the window
  
  road-flow-window  ;; table: road-id -> flow count in current window
  road-label-patches ;; table: road-id -> patch used for label
  
  ;; ----- road density (replaces avg speed) -----
  road-max-cars          ;; capacity per road (fixed = 36)
  road-car-sum           ;; table: road-id -> sum of cars observed across ticks in window
  road-car-ticks         ;; number of ticks accumulated in current window
  road-density-last      ;; table: road-id -> density (avgCars/36) for last completed window
  
  ticks-per-hour          ;; 1000 ticks = 1 hour
  current-hour            ;; current hour (0..23)
  last-hour               ;; to detect hour changes
  current-target-cars     ;; randomized target for THIS hour
  max-car-change-per-tick ;; smooth adjust toward target

  desired-target-cars      ;; sampled once per hour (can jump)
  change-per-hour          ;; cars per hour (smooth rate)
  change-accumulator       ;; fractional changes stored here
  
    ;; ----- churn (gradual replacement) -----
  churn-backlog           ;; how many cars still need to be replaced
  churn-per-hour          ;; how fast we replace cars (smooth)
  churn-accumulator       ;; stores fractional churn
  
    ;; ----- VC export (per 100-tick window) -----
  vc-history-rows        ;; list of [day time road_id vc density cars_in_window]
  day-index              ;; which simulated day (1..20)

  ;; total cars stats within the current 100-tick window
  car-count-sum          ;; sum of (count turtles) across ticks in current window
  car-count-ticks        ;; number of ticks accumulated in current window
  
  cbd-patches
  charge-window-ticks
  charge-counter
  total-toll-revenue
  
  toll-revenue-window     ;; revenue earned in current VC window (100 ticks)
  toll-revenue-hour       ;; revenue earned in current hour
  toll-revenue-day     ;; revenue earned in current 24-hour period
  last-day-index       ;; which 24h block we are in (0,1,2,...)
  
    ;; ----- Day-model Flow+Density experiment -----
  flow-density-window-ticks      ;; length of one measurement window (e.g. 100 ticks)
  flow-density-window-counter    ;; ticks elapsed in current window
  
  flow-density-records           ;; list of rows:
                                 ;; [run_id road_id time avg_total_cars flow_per_tick road_density]
  current-run-id                 ;; experiment run number (1..20)
  
  ;; ----- per-road average speed (window-based) -----
  road-speed-sum-window     ;; table: road_id -> sum of car speeds observed on that road (over window)
  road-speed-count-window   ;; table: road_id -> number of speed samples on that road (over window)
  
  cbd-entry-intersections   ;; intersections immediately outside CBD boundary
  cbd-left-x
  cbd-right-x
  cbd-top-y
  cbd-bottom-y

  ;; ----- Q-learning (RL) -----
  cbd-congestion-level   ;; 0 = low, 1 = medium, 2 = high (social signal)
  population-avg-q       ;; list of 30 Q-values (population average for inheritance)
]

turtles-own
[
  speed     ;; the speed of the turtle
  up-car?   ;; true if the turtle moves downwards and false if it moves to the right
  wait-time ;; the amount of time since the last time a turtle has moved
  was-on-camera?
  
  in-cbd?
  entered-cbd-this-window?
  toll-paid
  
  was-at-intersection?   ;; used to trigger turning only once per intersection entry
  decided-gate-this-step?   ;; prevents double-processing in the same tick
  avoid-cbd?          ;; this car currently wants to avoid CBD at the gate
  waiting-at-gate?    ;; true if it's queued on a CBD gate waiting for the non-CBD exit

  ;; ----- Q-learning (RL) -----
  q-table              ;; list of 30 values: Q(state * 2 + action)
  trip-start-tick      ;; tick when current gate decision was made
  trip-toll-paid       ;; toll accumulated during current trip
  last-state           ;; state index (0-14) when decision was made
  last-action          ;; 0 = avoid, 1 = enter
  has-pending-update?  ;; true if waiting to compute reward after gate decision
]

patches-own
[
  intersection?   ;; true if the patch is at the intersection of two roads
  green-light-up? ;; true if the green light is above the intersection.  otherwise, false.
                  ;; false for a non-intersection patches.
  my-row          ;; the row of the intersection counting from the upper left corner of the
                  ;; world.  -1 for non-intersection patches.
  my-column       ;; the column of the intersection counting from the upper left corner of the
                  ;; world.  -1 for non-intersection patches.
  my-phase        ;; the phase for the intersection.  -1 for non-intersection patches.
  auto?           ;; whether or not this intersection will switch automatically.
                  ;; false for non-intersection patches.
  camera?  ;; true if this patch is a traffic camera
  
  road-id  ;; string like "(0,2)" or "(1,3)"
  road-label?   ;; only one patch per long road shows the label
  
  base-pcolor
  cbd-core?
  cbd-gate?
]


;;;;;;;;;;;;;;;;;;;;;;
;; Setup Procedures ;;
;;;;;;;;;;;;;;;;;;;;;;

;; Initialize the display by giving the global and patch variables initial values.
;; Create num-cars of turtles if there are enough road patches for one turtle to
;; be created per road patch. Set up the plots.
to setup
  clear-all
  setup-globals
  set road-label-patches table:make
  ;; First we ask the patches to draw themselves and set up a few variables
  setup-patches
  make-current one-of intersections
  ;label-current
  
  set-default-shape turtles "car"

  if (num-cars > count roads)
  [
    user-message (word "There are too many cars for the amount of "
                       "road.  Either increase the amount of roads "
                       "by increasing the GRID-SIZE-X or "
                       "GRID-SIZE-Y sliders, or decrease the "
                       "number of cars by lowering the NUMBER slider.\n"
                       "The setup has stopped.")
    stop
  ]

  ;; Now create the turtles and have each created turtle call the functions setup-cars and set-car-color
  create-turtles num-cars
  [
    setup-cars
    set-car-color
    record-data

    ;; Q-learning init
    set q-table init-q-table-zeros
    set trip-start-tick 0
    set trip-toll-paid 0
    set last-state 0
    set last-action 0
    set has-pending-update? false
  ]

  ;; give the turtles an initial speed
  ask turtles [ 
    set-car-speed 
    set was-on-camera? false
  ]
  
  load-capacity-csv "csv/explored_data/capacity_per_road.csv"

  ;; Q-learning globals
  set cbd-congestion-level 0
  set population-avg-q init-q-table-zeros

  set road-flow-run table:make
  set road-flow-window table:make
  set road-car-sum table:make
  set road-density-last table:make
  set road-max-cars 36
  set road-car-ticks 0
  set vc-window 100
  set vc-tick-counter 0
  
  reset-ticks
end

;; Initialize the global variables to appropriate values
to setup-globals
  set current-light nobody ;; just for now, since there are no lights yet
  set phase 0
  set num-cars-stopped 0
  set grid-x-inc world-width / grid-size-x
  set grid-y-inc world-height / grid-size-y

  ;; don't make acceleration 0.1 since we could get a rounding error and end up on a patch boundary
  set acceleration 0.099
end

;; Make the patches have appropriate colors, set up the roads and intersections agentsets,
;; and initialize the traffic lights to one setting
to setup-patches
  ;; initialize the patch-owned variables and color the patches to a base-color
  ask patches
  [
    set intersection? false
    set auto? false
    set camera? false
    set green-light-up? true
    set my-row -1
    set my-column -1
    set my-phase -1
    set pcolor brown + 3
    set base-pcolor pcolor
  ]

  ;; initialize the global variables that hold patch agentsets
  set roads patches with
    [(floor((pxcor + max-pxcor - floor(grid-x-inc - 1)) mod grid-x-inc) = 0) or
    (floor((pycor + max-pycor) mod grid-y-inc) = 0)]
  set intersections roads with
    [(floor((pxcor + max-pxcor - floor(grid-x-inc - 1)) mod grid-x-inc) = 0) and
    (floor((pycor + max-pycor) mod grid-y-inc) = 0)]

  ask roads [ 
    set pcolor white 
    set base-pcolor pcolor
  ]
  setup-intersections
  setup-cameras
  label-roads
  highlight-rect
end

;; Give the intersections appropriate values for the intersection?, my-row, and my-column
;; patch variables.  Make all the traffic lights start off so that the lights are red
;; horizontally and green vertically.
to setup-intersections
  ask intersections
  [
    set intersection? true
    set green-light-up? true
    set my-phase 0
    set auto? true
    set my-row floor((pycor + max-pycor) / grid-y-inc)
    set my-column floor((pxcor + max-pxcor) / grid-x-inc)
    set-signal-colors
  ]
end

;; Initialize the turtle variables to appropriate values and place the turtle on an empty road patch.
to setup-cars  ;; turtle procedure
  set speed 0
  set wait-time 0
  put-on-empty-road
  ifelse intersection?
  [
    ifelse random 2 = 0
    [ set up-car? true ]
    [ set up-car? false ]
  ]
  [
    ; if the turtle is on a vertical road (rather than a horizontal one)
    ifelse (floor((pxcor + max-pxcor - floor(grid-x-inc - 1)) mod grid-x-inc) = 0)
    [ set up-car? true ]
    [ set up-car? false ]
  ]
  ifelse up-car?
  [ set heading 180 ]
  [ set heading 90 ]
  
  set was-at-intersection? false
  set decided-gate-this-step? false
  set avoid-cbd? false
  set waiting-at-gate? false
end

;; Find a road patch without any turtles on it and place the turtle there.
to put-on-empty-road  ;; turtle procedure
  move-to one-of roads with [not any? turtles-on self]
end

to setup-cameras
  ;; reset any previous camera marks (optional but safer)
  ask roads [
    set camera? false
    if pcolor = yellow [ set pcolor base-pcolor ]
  ]

  ;; Cameras for HORIZONTAL roads:
  ;; horizontal roads are the ones with pycor aligned to grid lines
  ;; so select road patches at pxcor = 7
  ask roads with [ pxcor = 7 ] [
    set camera? true
    set pcolor yellow
  ]

  ;; Cameras for VERTICAL roads:
  ;; vertical roads are the ones with pxcor aligned to grid lines
  ;; so select road patches at pycor = -7
  ask roads with [ pycor = -7 ] [
    set camera? true
    set pcolor yellow
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;
;; Runtime Procedures ;;
;;;;;;;;;;;;;;;;;;;;;;;;

;; Run the simulation
to go

  update-current

  ;; have the intersections change their color
  set-signals
  set num-cars-stopped 0

  ;; set the turtles speed for this time thru the procedure, move them forward their speed,
  ;; record data for plotting, and set the color of the turtles to an appropriate color
  ;; based on their speed
  ask turtles [
    set-car-speed
    maybe-turn-at-intersection   ;; <-- NEW (before moving)
    fd speed
    record-data
    set-car-color
  ]
  
  
  ;; update the phase and the global clock
  next-phase
  tick
end

to choose-current
  if mouse-down?
  [
    let x-mouse mouse-xcor
    let y-mouse mouse-ycor
    if [intersection?] of patch x-mouse y-mouse
    [
      update-current
      unlabel-current
      make-current patch x-mouse y-mouse
      label-current
      stop
    ]
  ]
end

;; Set up the current light and the interface to change it.
to make-current [light]
  set current-light light
  set current-phase [my-phase] of current-light
  set current-auto? [auto?] of current-light
end

;; update the variables for the current light
to update-current
  ask current-light [
    set my-phase current-phase
    set auto? current-auto?
  ]
end

;; label the current light
to label-current
  ask current-light
  [
    ask patch-at -1 1
    [
      set plabel-color black
      set plabel "current"
    ]
  ]
end

;; unlabel the current light (because we've chosen a new one)
to unlabel-current
  ask current-light
  [
    ask patch-at -1 1
    [
      set plabel ""
    ]
  ]
end

;; have the traffic lights change color if phase equals each intersections' my-phase
to set-signals
  ask intersections with [auto? and phase = floor ((my-phase * ticks-per-cycle) / 100)]
  [
    set green-light-up? (not green-light-up?)
    set-signal-colors
  ]
end

;; This procedure checks the variable green-light-up? at each intersection and sets the
;; traffic lights to have the green light up or the green light to the left.
to set-signal-colors  ;; intersection (patch) procedure
  ifelse power?
  [
    ifelse green-light-up?
    [
      ask patch-at -1 0 [ set pcolor red ]
      ask patch-at 0 1 [ set pcolor green ]
    ]
    [
      ask patch-at -1 0 [ set pcolor green ]
      ask patch-at 0 1 [ set pcolor red ]
    ]
  ]
  [
    ask patch-at -1 0 [ set pcolor white ]
    ask patch-at 0 1 [ set pcolor white ]
  ]
end

;; set the turtles' speed based on whether they are at a red traffic light or the speed of the
;; turtle (if any) on the patch in front of them
to set-car-speed  ;; turtle procedure
  ifelse pcolor = red
  [ set speed 0 ]
  [
    ifelse up-car?
    [ set-speed 0 -1 ]
    [ set-speed 1 0 ]
  ]
end

;; set the speed variable of the car to an appropriate value (not exceeding the
;; speed limit) based on whether there are cars on the patch in front of the car
to set-speed [ delta-x delta-y ]  ;; turtle procedure
  ;; get the turtles on the patch in front of the turtle
  let turtles-ahead turtles-at delta-x delta-y

  ;; if there are turtles in front of the turtle, slow down
  ;; otherwise, speed up
  ifelse any? turtles-ahead
  [
    ifelse any? (turtles-ahead with [ up-car? != [up-car?] of myself ])
    [
      set speed 0
    ]
    [
      set speed [speed] of one-of turtles-ahead
      slow-down
    ]
  ]
  [ speed-up ]
end

;; decrease the speed of the turtle
to slow-down  ;; turtle procedure
  ifelse speed <= 0  ;;if speed < 0
  [ set speed 0 ]
  [ set speed speed - acceleration ]
end

;; increase the speed of the turtle
to speed-up  ;; turtle procedure
  ifelse speed > speed-limit
  [ set speed speed-limit ]
  [ set speed speed + acceleration ]
end

;; set the color of the turtle to a different color based on how fast the turtle is moving
to set-car-color  ;; turtle procedure
  ifelse speed < (speed-limit / 2)
  [ set color blue ]
  [ set color cyan - 2 ]
end

;; keep track of the number of stopped turtles and the amount of time a turtle has been stopped
;; if its speed is 0
to record-data  ;; turtle procedure
  ifelse speed = 0
  [
    set num-cars-stopped num-cars-stopped + 1
    set wait-time wait-time + 1
  ]
  [ set wait-time 0 ]
end

to change-current
  ask current-light
  [
    set green-light-up? (not green-light-up?)
    set-signal-colors
  ]
end

;; cycles phase to the next appropriate value
to next-phase
  ;; The phase cycles from 0 to ticks-per-cycle, then starts over.
  set phase phase + 1
  if phase mod ticks-per-cycle = 0
    [ set phase 0 ]
end

to label-roads
  ;; clear previous road labels
  ask roads [
    set road-id ""
    set road-label? false
    set plabel ""
  ]

  ;; ---------------------------
  ;; Horizontal roads (0, N): top -> bottom
  ;; Use intersections row index (my-row) to define N
  ;; ---------------------------
  let row 0
  while [ row < grid-size-y ] [
    ;; find a reference intersection on this row to get the exact pycor line
    let ref one-of intersections with [ my-row = row ]
    if ref != nobody [
      let y-road [pycor] of ref
      let y-road-label y-road + 2
      let id (word "(" 0 "," (grid-size-y - 1 - row) ")")

      ;; all road patches along this horizontal line
      ask roads with [ pycor = y-road ] [
        set road-id id
      ]

      ;; show the label once, near the left edge
      let label-patch patch (min-pxcor + 5) y-road-label
      if label-patch != nobody [
        table:put road-label-patches id label-patch
        ask label-patch [
          set road-label? true
          set plabel id 
          set plabel-color black
        ]
      ]
    ]
    set row row + 1
  ]

  ;; ---------------------------
  ;; Vertical roads (1, N): left -> right
  ;; Use intersections column index (my-column) to define N
  ;; ---------------------------
  let col 0
  while [ col < grid-size-x ] [
    let ref one-of intersections with [ my-column = col ]
    if ref != nobody [
      let x-road [pxcor] of ref
      let x-road-label x-road - 1
      let id (word "(" 1 "," col ")")

      ;; all road patches along this vertical line
      ask roads with [ pxcor = x-road ] [
        set road-id id
      ]

      ;; show the label once, near the top edge
      let label-patch patch x-road-label max-pycor
      if label-patch != nobody [
        table:put road-label-patches id label-patch
        ask label-patch [
          set road-label? true
          set plabel id
          set plabel-color black
        ]
      ]
    ]
    set col col + 1
  ]
end

to count-camera-crossings
  ask turtles [
    let on_camera_now? [camera?] of patch-here

    if on_camera_now? and not was-on-camera? [
      let road_key [road-id] of patch-here
      if road_key != "" [
        ;; per-run count
        ifelse table:has-key? road-flow-run road_key
        [ table:put road-flow-run road_key (table:get road-flow-run road_key + 1) ]
        [ table:put road-flow-run road_key 1 ]

        ;; VC-window count
        ifelse table:has-key? road-flow-window road_key
        [ table:put road-flow-window road_key (table:get road-flow-window road_key + 1) ]
        [ table:put road-flow-window road_key 1 ]
      ]
    ]

    set was-on-camera? on_camera_now?
  ]
end

to-report all-road-ids
  ;; Generate all road ids in the SAME format you used in label-roads:
  ;; horizontal: (0,N) where N = grid-size-y-1-row
  ;; vertical:   (1,N) where N = col
  let ids []

  ;; horizontals (0,N)
  let r 0
  while [ r < grid-size-y ] [
    set ids lput (word "(" 0 "," (grid-size-y - 1 - r) ")") ids
    set r r + 1
  ]

  ;; verticals (1,N)
  let c 0
  while [ c < grid-size-x ] [
    set ids lput (word "(" 1 "," c ")") ids
    set c c + 1
  ]

  report ids
end

to export-vc-density-csv [filename]
  file-close-all
  file-open filename
  file-print "day,time,road_id,vc,density,cars_in_window,revenue_window,revenue_hour,revenue_day"

  foreach vc-history-rows [ row ->
    let d item 0 row
    let t item 1 row
    let road-key item 2 row
    let vc item 3 row
    let dens item 4 row
    let cars item 5 row
    let revW item 6 row
    let revH item 7 row
    let revD item 8 row

    file-print (word d "," t ",\"" road-key "\"," vc "," dens "," cars "," revW "," revH "," revD)
  ]

  file-close
end


to load-capacity-csv [filename]
  set cap-max-flow table:make
  set cap-flow-per-tick table:make

  let rows csv:from-file filename  ;; first row is header

  foreach but-first rows [ r ->
    let road-key item 0 r      ;; this stays a string like "(0,3)"
    let maxf item 1 r          ;; number (e.g., 156)
    let fpt  item 2 r          ;; number (e.g., 0.156)

    table:put cap-max-flow road-key maxf
    table:put cap-flow-per-tick road-key fpt
  ]
end


to-report capacity-of-patch
  let key road-id
  if table:has-key? cap-max-flow key [
    report table:get cap-max-flow key
  ]
  report 0
end

to update-vc-and-capacity
  ;; make sure history is a list (avoids lput crash)
  if not is-list? vc-history-rows [
    set vc-history-rows []
  ]
  
  ;; window end time label (HH:MM)
  let t current-time

  ;; average cars present during this window (rounded)
  let cars-in-window count turtles
  if car-count-ticks > 0 [
    set cars-in-window round (car-count-sum / car-count-ticks)
  ]

  ;; record for every road id (including zero-flow roads)
  foreach all-road-ids [ road_key ->

    ;; ---- FLOW (window) ----
    let flow 0
    if table:has-key? road-flow-window road_key [
      set flow table:get road-flow-window road_key
    ]

    ;; ---- CAPACITY + VC ----
    let vc 0
    if table:has-key? cap-flow-per-tick road_key [
      let capPerTick table:get cap-flow-per-tick road_key
      if capPerTick > 0 [
        let obsPerTick (flow / vc-window)
        set vc (obsPerTick / capPerTick)
      ]
    ]

    ;; ---- DENSITY (window) ----
    ;; avg cars on this road during the window, then divide by 36
    let avgCarsRoad 0
    if road-car-ticks > 0 [
      if table:has-key? road-car-sum road_key [
        set avgCarsRoad (table:get road-car-sum road_key / road-car-ticks)
      ]
    ]

    let density 0
    if road-max-cars > 0 [
      set density (avgCarsRoad / road-max-cars)
    ]
    table:put road-density-last road_key density


    ;; ---- LABEL (VC only or VC+speed, your choice) ----
    if table:has-key? road-label-patches road_key [
      ask table:get road-label-patches road_key [
        ;; show vc and speed nicely
        set plabel (word road_key precision vc 2)
        set plabel-color black
      ]
    ]

    ;; ---- STORE ROW FOR CSV ----
    set vc-history-rows
    lput (list day-index t road_key vc density cars-in-window
      toll-revenue-window toll-revenue-hour toll-revenue-day)
       vc-history-rows
  ]

  ;; reset window tables for next vc-window
  set road-flow-window table:make

  ;; reset density window
  set road-car-sum table:make
  set road-car-ticks 0

  ;; reset car counters for next window
  set car-count-sum 0
  set car-count-ticks 0

  ;; reset revenue for next vc-window
  set toll-revenue-window 0

end



to record-road-density
  ;; count cars per road THIS tick, then accumulate into road-car-sum
  let tickCounts table:make

  ask turtles [
    let rk [road-id] of patch-here
    if rk != "" [
      ifelse table:has-key? tickCounts rk
      [ table:put tickCounts rk (table:get tickCounts rk + 1) ]
      [ table:put tickCounts rk 1 ]
    ]
  ]

  ;; accumulate this tick into the window sum
  foreach table:keys tickCounts [ rk ->
    let c table:get tickCounts rk
    ifelse table:has-key? road-car-sum rk
    [ table:put road-car-sum rk (table:get road-car-sum rk + c) ]
    [ table:put road-car-sum rk c ]
  ]

  ;; count this tick in the window
  set road-car-ticks road-car-ticks + 1
end


to-report density-of-road [road-key]
  if table:has-key? road-density-last road-key [
    report table:get road-density-last road-key
  ]
  report 0
end


to-report target-cars-for-hour [h]
  ;; h is 0..23
  if h >= 1 and h <= 4 [ report 20 ]
  if h = 5  [ report 30 ]
  if h = 6  [ report 50 ]
  if h = 7  [ report 70 ]
  if h = 8  [ report 180 ]
  if h = 9  [ report 160 ]
  if h = 10 [ report 150 ]
  if h >= 11 and h <= 16 [ report 150 ]
  if h = 17 [ report 180 ]
  if h = 18 [ report 200 ]
  if h = 19 [ report 120 ]
  if h = 20 [ report 120 ]
  if h = 21 [ report 80 ]
  if h = 22 [ report 40 ]
  if h = 23 [ report 40 ]
  report 30  ;; default (00:00)
end

to setup-hourly-traffic
  set ticks-per-hour 600

  ;; how fast to change cars (cars per hour)
  set change-per-hour 150          ;; try 60 first (very slow). 200 is faster.
  set change-accumulator 0

  set last-hour -1
  set current-hour start-hour

  ;; sample the hourly demand (±10%) once
  set desired-target-cars sample-target-for-hour start-hour

  ;; start by matching target (no jump inside the run)
  set current-target-cars desired-target-cars
end


to-report sample-target-for-hour [h]
  ;; get the base number of cars for this hour (from your table)
  let base target-cars-for-hour h

  ;; calculate -10% and +10% range
  let low  floor (base * 0.9)
  let high ceiling (base * 1.1)

  ;; pick ONE random number inside the range
  ;; this number will be used for the whole hour
  report (low + random (high - low + 1))
end


to update-hour-and-sample-target
  ;; how many full hours have passed since start
  ;; (1000 ticks = 1 hour)
  let hour-index floor (ticks / ticks-per-hour)

  ;; calculate current hour of day (start at 6am)
  ;; mod 24 makes sure it wraps after 23
  set current-hour ((start-hour + hour-index) mod 24)

  ;; only do something when we enter a NEW hour
  if current-hour != last-hour [

    set last-hour current-hour

    ;; NEW HOUR: reset hourly revenue
    set toll-revenue-hour 0

    set desired-target-cars sample-target-for-hour current-hour
    on-new-hour-churn-setup
  ]
end

to-report sign [x]
  if x > 0 [ report 1 ]
  if x < 0 [ report -1 ]
  report 0
end


to apply-hourly-demand
  ;; step 1: update hour and (maybe) sample a new desired target
  update-hour-and-sample-target

  ;; step 2: gradually move car count toward desired-target-cars
  let diff (desired-target-cars - count turtles)
  if diff = 0 [
    churn-step
    stop
  ]

  ;; cars-per-hour -> cars-per-tick
  let max-change-per-tick (change-per-hour / ticks-per-hour)

  ;; wanted change this tick (can be fractional)
  let desired-change diff
  if abs desired-change > max-change-per-tick [
    set desired-change (max-change-per-tick * sign diff)
  ]

  ;; accumulate fractional change
  set change-accumulator change-accumulator + desired-change

  ;; only when we reach +/- 1 do we actually create/kill 1 car
  while [ abs change-accumulator >= 1 ] [
    if change-accumulator >= 1 [
      add-cars 1
      set change-accumulator change-accumulator - 1
    ]
    if change-accumulator <= -1 [
      remove-cars 1
      set change-accumulator change-accumulator + 1
    ]
  ]
end

;; call this ONLY when a new hour begins
to on-new-hour-churn-setup
  ;; replace 30% of this hour's cars, rounded up
  set churn-per-hour ceiling (0.30 * desired-target-cars)

  ;; schedule the total replacements to do during this hour
  set churn-backlog churn-per-hour

  ;; reset accumulator so the hour starts clean
  set churn-accumulator 0
end

to churn-step
  ;; only churn when stable at target (so car count stays constant)
  if count turtles != desired-target-cars [ stop ]

  ;; if nothing scheduled, do nothing
  if churn-backlog <= 0 [ stop ]

  ;; convert cars/hour -> cars/tick
  let churn-per-tick (churn-per-hour / ticks-per-hour)

  ;; accumulate fractional churn
  set churn-accumulator churn-accumulator + churn-per-tick

  ;; whenever we reach 1, replace 1 car
  while [ churn-accumulator >= 1 and churn-backlog > 0 ] [
    if any? turtles [ ask one-of turtles [ die ] ]
    add-cars 1

    set churn-backlog churn-backlog - 1
    set churn-accumulator churn-accumulator - 1
  ]
end


to add-cars [n]
  if n <= 0 [ stop ]

  let empty-roads roads with [not any? turtles-on self]
  let possible min list n (count empty-roads)
  if possible <= 0 [ stop ]

  create-turtles possible [
    setup-cars
    set-car-color
    set was-on-camera? false
    set-car-speed
    record-data

    ;; CBD charging flags
    set in-cbd? false
    set entered-cbd-this-window? false
    set toll-paid 0

    set was-at-intersection? false
    set decided-gate-this-step? false
    set avoid-cbd? false
    set waiting-at-gate? false

    ;; Q-learning: inherit population knowledge (social learning)
    set q-table init-q-table-from-population
    set trip-start-tick 0
    set trip-toll-paid 0
    set last-state 0
    set last-action 0
    set has-pending-update? false
  ]
end


to remove-cars [n]
  if n <= 0 [ stop ]
  if count turtles = 0 [ stop ]
  ask n-of (min list n (count turtles)) turtles [die]
end


to-report current-time
  ;; current hour (0..23)
  let h current-hour

  ;; minutes inside the hour (0..59)
  let m floor ((ticks mod ticks-per-hour) / (ticks-per-hour / 60))

  ;; format minutes with leading zero
  if m < 10 [
    report word h (word ":0" m)
  ]

  report word h (word ":" m)
end



to setup-day
  clear-all

  setup-globals
  set road-label-patches table:make
  setup-patches
  make-current one-of intersections

  set-default-shape turtles "car"

  ;; load capacity data
  load-capacity-csv "csv/explored_data/capacity_per_road.csv"

  ;; init tables
  set road-flow-run table:make
  set road-flow-window table:make
  set road-car-sum table:make
  set road-density-last table:make
  set road-max-cars 36
  set road-car-ticks 0
  set vc-window 100
  set vc-tick-counter 0

  ;; ticks must be reset BEFORE using day logic
  reset-ticks
  
  
  set last-day-index 0

    ;; ----- init vc export storage (do NOT clear vc-history-rows here) -----
  set car-count-sum 0
  set car-count-ticks 0

  ;; setup day-time system (hour, target cars)
  setup-hourly-traffic
  
    ;; ---- CBD + charging init ----
  setup-cbd                 ;; defines cbd-patches (includes roads)
  show (word "gate count = " count cbd-entry-intersections)

  ;; highlight-rect already called in setup-patches (visual)

  set charge-window-ticks (charge-hour * ticks-per-hour)
  set charge-counter 0
  set total-toll-revenue 0
  set toll-revenue-window 0
  set toll-revenue-hour 0
  set toll-revenue-day 0
  set last-day-index 0

  ;; ---- Q-learning globals ----
  set cbd-congestion-level 0
  if not is-list? population-avg-q [ set population-avg-q init-q-table-zeros ]

  ;; create starting cars based on chosen hour
  if current-target-cars > count roads [
    user-message "Too many cars for the amount of road."
    stop
  ]

  create-turtles current-target-cars [
    setup-cars
    set-car-color
    set was-on-camera? false
    set-car-speed
    record-data

    ;; CBD charging flags
    set in-cbd? false
    set entered-cbd-this-window? false
    set toll-paid 0

    ;; Q-learning init
    set q-table init-q-table-from-population
    set trip-start-tick 0
    set trip-toll-paid 0
    set last-state 0
    set last-action 0
    set has-pending-update? false
  ]

end

to go-day
  update-current
  set-signals
  set num-cars-stopped 0

  ;; ---- day rollover: every 24 hours, reset day revenue ----
  ;; (toll-revenue-day counts "today so far" and restarts from 0 each 24h block)
  let day-now floor (ticks / (24 * ticks-per-hour))
  if day-now != last-day-index [
    set last-day-index day-now
    set toll-revenue-day 0
  ]

  ask turtles [
    set-car-speed
    maybe-turn-at-intersection  ;; <-- NEW (before moving)
    fd speed
    record-data
    set-car-color
  ]


  count-camera-crossings
  record-road-density

  ;; ---- CBD charging ----
  update-cbd-entry-flags
  cbd-charge-step

  ;; ---- Q-learning: check reward triggers ----
  if use-learning? [
    ask turtles [ check-reward-trigger ]
  ]

  ;; accumulate total car presence in this vc-window
  set car-count-sum (car-count-sum + count turtles)
  set car-count-ticks (car-count-ticks + 1)

  ;; hourly demand + replacement logic
  apply-hourly-demand

  ;; VC window logic (unchanged)
  set vc-tick-counter vc-tick-counter + 1
  if vc-tick-counter >= vc-window [
    update-vc-and-capacity
    set vc-tick-counter 0

    ;; ---- Q-learning: update social signal + population avg ----
    if use-learning? [
      update-cbd-congestion-level
      compute-population-avg-q
    ]
  ]

  next-phase
  tick
end


to export-vc-speed-csv [filename]
  file-close-all
  file-open filename
  file-print "day,time,road_id,vc,avg_speed,cars_in_window"

  foreach vc-history-rows [ row ->
    let d item 0 row
    let t item 1 row
    let road-key item 2 row
    let vc item 3 row
    let avgS item 4 row
    let cars item 5 row

    ;; quote road id so Excel doesn't split "(0,4)"
    file-print (word d "," t ",\"" road-key "\"," vc "," avgS "," cars)
  ]

  file-close
end

to setup-day-batch
  ;; DON'T clear-all (it wipes day-index + vc-history-rows)
  clear-turtles
  clear-drawing
  clear-all-plots

  setup-globals
  set road-label-patches table:make
  setup-patches
  make-current one-of intersections

  set-default-shape turtles "car"

  load-capacity-csv "csv/explored_data/capacity_per_road.csv"

  set road-flow-run table:make
  set road-flow-window table:make
  set road-car-sum table:make
  set road-density-last table:make
  set road-max-cars 36
  set road-car-ticks 0


  set vc-window 100
  set vc-tick-counter 0

  reset-ticks

  set car-count-sum 0
  set car-count-ticks 0

  setup-hourly-traffic
    ;; ---- CBD + charging init ----
  setup-cbd
  set charge-window-ticks (charge-hour * ticks-per-hour)
  set charge-counter 0
  set total-toll-revenue 0
  set toll-revenue-window 0
  set toll-revenue-hour 0
  set toll-revenue-day 0
  set last-day-index 0

  ;; ---- Q-learning: keep population-avg-q across days (persistent learning) ----
  set cbd-congestion-level 0

  if current-target-cars > count roads [
    user-message "Too many cars for the amount of road."
    stop
  ]

create-turtles current-target-cars [
  setup-cars
  set-car-color
  set was-on-camera? false
  set-car-speed
  record-data

  ;; CBD charging flags
  set in-cbd? false
  set entered-cbd-this-window? false
  set toll-paid 0

  ;; Q-learning init
  set q-table init-q-table-from-population
  set trip-start-tick 0
  set trip-toll-paid 0
  set last-state 0
  set last-action 0
  set has-pending-update? false
]

end


to run-20-days-and-export
  set vc-history-rows []
  set population-avg-q init-q-table-zeros  ;; fresh learning across days

  set day-index 1
  while [ day-index <= 20 ] [
    setup-day-batch
    show day-index

    repeat (24 * ticks-per-hour) [
      go-day
    ]

    set day-index day-index + 1
  ]

  export-vc-density-csv (vc-density-export-filename 20)
end


to highlight-rect
  ask patches with [
    pxcor >= -7 and pxcor <= 6 and
    pycor <= 8 and pycor >= -6 and
    not member? self roads     
  ] [
    set pcolor sky + 3         ;; light blue "transparent" look
  ]
end

to setup-cbd
  ;; reset flags
  ask patches [
    set cbd-core? false
    set cbd-gate? false
  ]

  ;; CBD core ONLY on roads (aligns to network)
  ask roads with [
    pxcor >= -6 and pxcor <= 5 and
    pycor >= -5 and pycor <= 7
  ] [
    set cbd-core? true
  ]

  set cbd-patches roads with [ cbd-core? ]

  ;; -----------------------------
  ;; ✅ Decision gates (UPSTREAM ONLY)
  ;; A gate is an INTERSECTION outside CBD-core such that
  ;; either the EAST neighbor OR SOUTH neighbor is a CBD-core ROAD.
  ;; This matches your movement model (east/south only).
  ;; -----------------------------
  ;; Gate intersections (decision points):
  ;; intersection is outside core, and exactly ONE outbound direction (E or S) enters core
  set cbd-entry-intersections intersections with [
    (not cbd-core?) and
    (east-enters-core? != south-enters-core?) and
    (
      (east-enters-core?  and upstream-east-gate?) or
      (south-enters-core? and upstream-south-gate?)
    )
  ]


  ask cbd-entry-intersections [
    set cbd-gate? true
    set pcolor magenta
  ]

  show (word "gate count = " count cbd-entry-intersections)
  show sort [ (list pxcor pycor) ] of cbd-entry-intersections
end


to update-cbd-entry-flags
  ask turtles [
    let now-in (member? patch-here cbd-patches)

    ;; outside -> inside = entry
    if now-in and not in-cbd? [

      ;; only charge once per window
      if not entered-cbd-this-window? [
        set entered-cbd-this-window? true

        ;; CHARGE IMMEDIATELY
        set toll-paid toll-paid + charge-fee
        set trip-toll-paid trip-toll-paid + charge-fee  ;; track for Q-learning reward
        set total-toll-revenue total-toll-revenue + charge-fee
        set toll-revenue-window toll-revenue-window + charge-fee
        set toll-revenue-hour   toll-revenue-hour   + charge-fee
        set toll-revenue-day    toll-revenue-day    + charge-fee
      ]
    ]

    set in-cbd? now-in
  ]
end


to cbd-charge-step
  if charge-window-ticks <= 0 [ stop ]

  set charge-counter charge-counter + 1

  if charge-counter >= charge-window-ticks [
    ;; new window begins: allow cars to be charged again
    ask turtles [ set entered-cbd-this-window? false ]
    set charge-counter 0
  ]
end

to-report vc-density-export-filename [days]
  ;; Build a filename that includes the key experiment settings (sliders + model config)
  ;; Example:
  ;; csv/raw_data/vc_density_days_20_start_6_chargeH_6_fee_4_tph_600_vcw_100.csv

  report (word
    "csv/raw_data/"
    "vc_density_"
    "days_" days "_"
    "start_" start-hour "_"
    "chargeH_" charge-hour "_"
    "fee_" charge-fee "_"
    "tph_" ticks-per-hour "_"
    "vcw_" vc-window
    ".csv"
  )
end

to run-20-days-continuous-and-export
  ;; fresh VC storage
  set vc-history-rows []
  set population-avg-q init-q-table-zeros  ;; fresh learning across days

  ;; reset day tracking
  set day-index 1
  set last-day-index 0

  ;; local run tag based on current ticks (always changes across runs)
  let run-tag ticks

  let total-ticks (20 * 24 * ticks-per-hour)

  repeat total-ticks [
    go-day

    ;; print progress at end of each day
    if ticks mod (24 * ticks-per-hour) = 0 [
      set day-index (ticks / (24 * ticks-per-hour))
      show (word "Finished day " day-index)
    ]
  ]

  ;; export with UNIQUE filename
  export-vc-density-csv (vc-density-export-filename-continuous 20 run-tag)
end

to-report vc-density-export-filename-continuous [days run-tag]
  report (word
    "csv/raw_data/"
    "vc_density_continuous_"
    "days_" days "_"
    "start_" start-hour "_"
    "chargeH_" charge-hour "_"
    "fee_" charge-fee "_"
    "tph_" ticks-per-hour "_"
    "vcw_" vc-window "_"
    "tag_" run-tag
    ".csv"
  )
end

to record-flow-density-window
  if not is-list? flow-density-records [
    set flow-density-records []
  ]

  let window-time current-time

  ;; average total cars in system during this window
  let avg-system-cars count turtles
  if car-count-ticks > 0 [
    set avg-system-cars round (car-count-sum / car-count-ticks)
  ]

  foreach all-road-ids [ road-id-key ->

    ;; ----------------------------------
    ;; FLOW (RAW camera count + per tick)
    ;; ----------------------------------
    let window-flow-count 0
    if table:has-key? road-flow-window road-id-key [
      set window-flow-count table:get road-flow-window road-id-key
    ]

    let flow-per-tick (window-flow-count / flow-density-window-ticks)

    ;; ----------------------------------
    ;; DENSITY
    ;; ----------------------------------
    let avg-cars-on-road 0
    if road-car-ticks > 0 [
      if table:has-key? road-car-sum road-id-key [
        set avg-cars-on-road
          (table:get road-car-sum road-id-key / road-car-ticks)
      ]
    ]

    let road-density 0
    if road-max-cars > 0 [
      set road-density (avg-cars-on-road / road-max-cars)
    ]

    ;; ----------------------------------
    ;; AVG SPEED PER ROAD
    ;; ----------------------------------
    let avg-speed-road 0
    if table:has-key? road-speed-count-window road-id-key [
      let n table:get road-speed-count-window road-id-key
      if n > 0 [
        set avg-speed-road
          (table:get road-speed-sum-window road-id-key / n)
      ]
    ]

    ;; ----------------------------------
    ;; STORE ROW (NOW INCLUDES RAW FLOW)
    ;; ----------------------------------
    set flow-density-records
      lput (list
        current-run-id
        road-id-key
        window-time
        avg-system-cars
        window-flow-count          ;; 🔴 NEW (raw camera count)
        flow-per-tick
        road-density
        avg-speed-road
      )
      flow-density-records
  ]

  ;; reset window accumulators
  set road-flow-window table:make
  set road-car-sum table:make
  set road-car-ticks 0
  set car-count-sum 0
  set car-count-ticks 0
  set road-speed-sum-window table:make
  set road-speed-count-window table:make
end



to export-flow-density-csv [filename]
  file-close-all
  file-open filename

  file-print
    "run_id,road_id,time,avg_system_cars,window_flow_count,flow_per_tick,road_density,avg_speed_road"

  foreach flow-density-records [ row ->
    let run-id        item 0 row
    let road-id-key   item 1 row
    let time-label    item 2 row
    let sys-cars      item 3 row
    let win-flow      item 4 row   ;; NEW
    let fpt           item 5 row
    let dens          item 6 row
    let avgSp         item 7 row

    file-print (word
      run-id ",\"" road-id-key "\"," time-label ","
      sys-cars "," win-flow ","
      precision fpt 6 "," precision dens 6 "," precision avgSp 6
    )
  ]

  file-close
end




to setup-flow-density-run
  ;; do NOT clear-all: controller manages run counter & exports
  clear-turtles
  clear-drawing
  clear-all-plots

  setup-globals
  set road-label-patches table:make
  setup-patches
  make-current one-of intersections

  set-default-shape turtles "car"

  ;; ----------------------------------
  ;; Measurement state
  ;; ----------------------------------
  set road-flow-window table:make
  set road-car-sum table:make
  ;; per-road speed accumulators (reset each run)
  set road-speed-sum-window table:make
  set road-speed-count-window table:make
  
  set road-car-ticks 0
  set road-max-cars 36

  set flow-density-window-ticks 100
  set flow-density-window-counter 0
 
  reset-ticks

  ;; track average total cars
  set car-count-sum 0
  set car-count-ticks 0

  ;; ----------------------------------
  ;; Day-time demand system
  ;; ----------------------------------
  setup-hourly-traffic

  ;; ---- Q-learning globals ----
  set cbd-congestion-level 0
  if not is-list? population-avg-q [ set population-avg-q init-q-table-zeros ]

  ;; create initial cars for starting hour
  if current-target-cars > count roads [
    user-message "Too many cars for the amount of road."
    stop
  ]

  create-turtles current-target-cars [
    setup-cars
    set-car-speed
    set-car-color
    set was-on-camera? false
    record-data

    ;; Q-learning init
    set q-table init-q-table-from-population
    set trip-start-tick 0
    set trip-toll-paid 0
    set last-state 0
    set last-action 0
    set has-pending-update? false
  ]
end

to go-flow-density
  update-current
  set-signals
  set num-cars-stopped 0

  ask turtles [
    set-car-speed
    maybe-turn-at-intersection   ;; <-- NEW (before moving)
    fd speed
    record-data
    set-car-color
  ]


  ;; measurements
  count-camera-crossings
  record-road-density
  record-road-speed

  ;; ---- Q-learning: check reward triggers ----
  if use-learning? [
    ask turtles [ check-reward-trigger ]
  ]

  ;; average total cars
  set car-count-sum (car-count-sum + count turtles)
  set car-count-ticks (car-count-ticks + 1)

  ;; hourly demand + churn
  apply-hourly-demand

  ;; window rollover
  set flow-density-window-counter
      flow-density-window-counter + 1

  if flow-density-window-counter >= flow-density-window-ticks [
    record-flow-density-window
    set flow-density-window-counter 0

    ;; ---- Q-learning: update social signal + population avg ----
    if use-learning? [
      update-cbd-congestion-level
      compute-population-avg-q
    ]
  ]

  next-phase
  tick
end

to run-20-day-flow-density-experiment
  set flow-density-records []
  set population-avg-q init-q-table-zeros  ;; fresh learning across runs

  set current-run-id 1
  while [ current-run-id <= 20 ] [
    setup-flow-density-run
    show (word "Flow & density run " current-run-id)

    repeat (24 * ticks-per-hour) [
      go-flow-density
    ]

    set current-run-id current-run-id + 1
  ]

  export-flow-density-csv (flow-density-export-filename 20)
end

to-report flow-density-export-filename [runs]
  report (word
    "csv/raw_data/"
    "flow_density_runs_" runs
    "_start_" start-hour
    "_tph_" ticks-per-hour
    "_window_" flow-density-window-ticks
    ".csv"
  )
end

to record-road-speed
  ;; accumulates speed samples per road for THIS tick
  ;; (each car contributes one sample: its current speed on its current road)

  ask turtles [
    let road-key [road-id] of patch-here
    if road-key != "" [

      ;; sum of speeds
      ifelse table:has-key? road-speed-sum-window road-key
      [ table:put road-speed-sum-window road-key
          (table:get road-speed-sum-window road-key + speed) ]
      [ table:put road-speed-sum-window road-key speed ]

      ;; count of samples
      ifelse table:has-key? road-speed-count-window road-key
      [ table:put road-speed-count-window road-key
          (table:get road-speed-count-window road-key + 1) ]
      [ table:put road-speed-count-window road-key 1 ]
    ]
  ]
end

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Q-Learning Procedures    ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Map hour (0-23) to time-period bucket (0-4)
to-report time-period-bucket [h]
  if h >= 0 and h <= 5  [ report 0 ]  ;; night
  if h >= 6 and h <= 9  [ report 1 ]  ;; am-peak
  if h >= 10 and h <= 16 [ report 2 ] ;; midday
  if h >= 17 and h <= 21 [ report 3 ] ;; pm-peak
  report 4                             ;; evening (22-23)
end

;; Compute current state index (0-14) from time-period and congestion-level
to-report current-state-index
  report (time-period-bucket current-hour) * 3 + cbd-congestion-level
end

;; Index into flat Q-table list: state * 2 + action
to-report q-index [s a]
  report s * 2 + a
end

;; Create a fresh Q-table (list of 30 zeros)
to-report init-q-table-zeros
  report n-values 30 [0]
end

;; Create a Q-table initialized from population averages (social inheritance)
to-report init-q-table-from-population
  if not is-list? population-avg-q [ report init-q-table-zeros ]
  if empty? population-avg-q [ report init-q-table-zeros ]
  report population-avg-q
end

;; Update the global cbd-congestion-level based on average CBD road density
to update-cbd-congestion-level
  ;; guard: cbd-patches must exist
  if not is-agentset? cbd-patches [ stop ]

  ;; compute average density across CBD roads
  let cbd-road-ids []
  ask cbd-patches with [ road-id != "" ] [
    if not member? road-id cbd-road-ids [
      set cbd-road-ids lput road-id cbd-road-ids
    ]
  ]

  let avg-density 0
  if not empty? cbd-road-ids [
    let total 0
    foreach cbd-road-ids [ rid ->
      set total total + density-of-road rid
    ]
    set avg-density total / length cbd-road-ids
  ]

  ;; bucket into 0/1/2
  ifelse avg-density < 0.3 [
    set cbd-congestion-level 0
  ] [
    ifelse avg-density < 0.6 [
      set cbd-congestion-level 1
    ] [
      set cbd-congestion-level 2
    ]
  ]
end

;; Compute population-average Q-values across all living turtles
to compute-population-avg-q
  if not any? turtles [ stop ]

  let n count turtles
  let sums n-values 30 [0]

  ask turtles [
    if is-list? q-table and length q-table = 30 [
      let i 0
      while [i < 30] [
        set sums replace-item i sums ((item i sums) + (item i q-table))
        set i i + 1
      ]
    ]
  ]

  set population-avg-q map [ x -> x / n ] sums
end

;; Epsilon-greedy action selection: returns 0 (avoid) or 1 (enter)
to-report choose-action-rl  ;; turtle procedure
  let s current-state-index

  ;; exploration
  if random-float 1 < epsilon [
    report random 2
  ]

  ;; exploitation: pick action with higher Q
  let q-avoid item (q-index s 0) q-table
  let q-enter item (q-index s 1) q-table

  ifelse q-enter > q-avoid [
    report 1
  ] [
    ifelse q-enter < q-avoid [
      report 0
    ] [
      report random 2  ;; tie-break randomly
    ]
  ]
end

;; Update Q-value after receiving reward
to update-q-value [reward]  ;; turtle procedure
  if not has-pending-update? [ stop ]

  let idx q-index last-state last-action
  let old-q item idx q-table
  let new-q old-q + learning-rate * (reward - old-q)
  set q-table replace-item idx q-table new-q

  set has-pending-update? false
end

;; Check if a car that made a gate decision should now receive its reward
to check-reward-trigger  ;; turtle procedure
  if not has-pending-update? [ stop ]
  if not use-learning? [ stop ]

  ;; Guard: cbd-patches must exist
  if not is-agentset? cbd-patches [ stop ]

  ;; Reward triggers:
  ;; (A) Car chose to ENTER (last-action = 1): reward when it exits CBD
  ;; (B) Car chose to AVOID (last-action = 0): reward when it leaves the gate intersection

  ifelse last-action = 1 [
    ;; entered CBD: reward when no longer in CBD
    if not (member? patch-here cbd-patches) and in-cbd? = false [
      let trip-time (ticks - trip-start-tick)
      let reward (- (trip-toll-paid + time-cost-weight * trip-time))
      update-q-value reward
    ]
  ] [
    ;; avoided CBD: reward as soon as car moves off the gate intersection
    if not [cbd-gate?] of patch-here [
      let trip-time (ticks - trip-start-tick)
      let reward (- (time-cost-weight * trip-time))  ;; no toll paid
      update-q-value reward
    ]
  ]
end

to maybe-turn-at-intersection  ;; turtle procedure
  if not intersection? [
    set was-at-intersection? false
    set waiting-at-gate? false
    set avoid-cbd? false
    stop
  ]

  ;; Only handle CBD gates (guard: cbd-entry-intersections may not exist in some modes)
  if not is-agentset? cbd-entry-intersections [ stop ]
  if not member? patch-here cbd-entry-intersections [
    ;; normal intersection behaviour: no turning logic
    if not was-at-intersection? [ set was-at-intersection? true ]
    stop
  ]

  ;; We are on a CBD gate intersection
  ;; Snap to center to reduce weird drift
  move-to patch-here

  ;; compute straight/turn targets from THIS intersection
  let straight-target nobody
  let turn-target nobody

  ifelse up-car? [
    set straight-target patch-at 0 -1   ;; south
    set turn-target     patch-at 1  0   ;; east
  ] [
    set straight-target patch-at 1  0   ;; east
    set turn-target     patch-at 0 -1   ;; south
  ]

  ;; validity checks
  let straight-ok? (straight-target != nobody and member? straight-target roads and not any? turtles-on straight-target)
  let turn-ok?     (turn-target     != nobody and member? turn-target     roads and not any? turtles-on turn-target)

  ;; does each option enter CBD core?  (use your corridor-based reporters)
  let straight-enters? false
  let turn-enters? false

  ifelse up-car? [
    ;; moving south: straight uses SOUTH corridor, turn uses EAST corridor
    set straight-enters? south-enters-core?
    set turn-enters?     east-enters-core?
  ] [
    ;; moving east: straight uses EAST corridor, turn uses SOUTH corridor
    set straight-enters? east-enters-core?
    set turn-enters?     south-enters-core?
  ]

  ;; If not a true gate (both enter or both avoid), do nothing
  if (straight-enters? = turn-enters?) [
    stop
  ]

  ;; -----------------------------
  ;; (A) If we are already waiting to avoid CBD, keep waiting until the non-CBD exit is free
  ;; -----------------------------
if waiting-at-gate? and avoid-cbd? [

  ;; the non-CBD exit is whichever does NOT enter CBD
  let avoid-target nobody
  ifelse straight-enters? [
    set avoid-target turn-target
  ] [
    set avoid-target straight-target
  ]

  let avoid-ok? (avoid-target != nobody and member? avoid-target roads and not any? turtles-on avoid-target)

  ifelse avoid-ok? [

    ;; if avoid-target is the "turn" option, actually turn now
    if avoid-target = turn-target [
      set up-car? (not up-car?)
      ifelse up-car? [ set heading 180 ] [ set heading 90 ]
      move-to avoid-target
    ]

    ;; done waiting
    set waiting-at-gate? false
    set speed 0  ;; don't move twice in same tick

  ] [

    ;; keep waiting on the intersection until avoid-target has space
    set speed 0
  ]

  stop
]


  ;; -----------------------------
  ;; (B) First time arriving at gate: decide enter/avoid
  ;; -----------------------------
  if not was-at-intersection? [
    set was-at-intersection? true

    ;; Decision: RL-based or original probability-based
    let want-enter? false
    ifelse use-learning? [
      let chosen-action choose-action-rl
      set want-enter? (chosen-action = 1)

      ;; record state/action for later Q-update
      set last-state current-state-index
      set last-action chosen-action
      set trip-start-tick ticks
      set trip-toll-paid 0
      set has-pending-update? true
    ] [
      set want-enter? (random-float 1 < cbd-entry-probability)
    ]
    set avoid-cbd? (not want-enter?)

    ;; If we want to avoid CBD:
    ;; - if the non-CBD exit is blocked, START WAITING
    ;; - otherwise turn away immediately (if needed)
    if avoid-cbd? [
      ;; identify non-CBD exit
      let avoid-target nobody
      let avoid-is-turn? false

      ifelse straight-enters? [
        set avoid-target turn-target
        set avoid-is-turn? true
      ] [
        set avoid-target straight-target
        set avoid-is-turn? false
      ]

      let avoid-ok? (avoid-target != nobody and member? avoid-target roads and not any? turtles-on avoid-target)

      if not avoid-ok? [
        set waiting-at-gate? true
        set speed 0
        stop
      ]

      ;; avoid is possible now: execute turn if needed
      if avoid-is-turn? [
        set up-car? (not up-car?)
        ifelse up-car? [ set heading 180 ] [ set heading 90 ]
        move-to avoid-target
        set speed 0
      ]
      stop
    ]

    ;; If we want to enter CBD:
    ;; Do nothing special — car will naturally go via the CBD-entering exit if it’s straight,
    ;; or you can also force the entering turn here (optional).
    stop
  ]

  ;; if still on intersection but not first-entry tick, do nothing
end


to-report charge-dollars-per-hour
  if charge-hour <= 0 [ report 0 ]
  report (charge-fee / charge-hour)
end

to-report cbd-entry-probability
  ;; base: if no charging OR already charged, it becomes to-cbd-rate elsewhere
  let p to-cbd-rate

  ;; charging off => no change
  if (charge-fee <= 0) or (charge-hour <= 0) [ report p ]

  ;; charging on: reduce entry using $/hour
  let r charge-dollars-per-hour
  set p (p * exp (- beta-charge * r))

  ;; keep CBD always possible
  set p max list min-cbd-entry p
  set p min list (1 - min-cbd-entry) p

  report p
end

to-report east-core?  ;; patch reporter
  let p patch-at 1 0
  if p = nobody [ report false ]
  if not member? p roads [ report false ]
  report [cbd-core?] of p
end

to-report south-core?  ;; patch reporter
  let p patch-at 0 -1
  if p = nobody [ report false ]
  if not member? p roads [ report false ]
  report [cbd-core?] of p
end

;; From an INTERSECTION: does the EAST corridor reach CBD core
;; before the next intersection (there can be many road patches in between)?
to-report east-enters-core?
  let step 1
  let p patch-at step 0

  while [ p != nobody and member? p roads and not [intersection?] of p ] [
    if [cbd-core?] of p [ report true ]
    set step step + 1
    set p patch-at step 0
  ]

  ;; also check the next intersection patch if it exists
  if p != nobody and member? p roads [
    if [cbd-core?] of p [ report true ]
  ]

  report false
end

to-report south-enters-core?
  let step 1
  let p patch-at 0 (- step)

  while [ p != nobody and member? p roads and not [intersection?] of p ] [
    if [cbd-core?] of p [ report true ]
    set step step + 1
    set p patch-at 0 (- step)
  ]

  if p != nobody and member? p roads [
    if [cbd-core?] of p [ report true ]
  ]

  report false
end

to-report upstream-east-gate?
  if not east-enters-core? [ report false ]

  ;; nearest intersection to the WEST
  let step 1
  let p patch-at (- step) 0

  while [ p != nobody and member? p roads and not [intersection?] of p ] [
    set step step + 1
    set p patch-at (- step) 0
  ]

  if p != nobody and [intersection?] of p [
    if [east-enters-core?] of p [ report false ]
  ]

  report true
end

to-report upstream-south-gate?
  if not south-enters-core? [ report false ]

  ;; nearest intersection to the NORTH
  let step 1
  let p patch-at 0 step

  while [ p != nobody and member? p roads and not [intersection?] of p ] [
    set step step + 1
    set p patch-at 0 step
  ]

  if p != nobody and [intersection?] of p [
    if [south-enters-core?] of p [ report false ]
  ]

  report true
end
]]></code>
